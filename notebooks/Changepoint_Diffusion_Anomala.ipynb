    "\n",
    "# (a) RMSE\n",
    "eje = ejes[0, 0]\n",
    "eje.plot(posiciones_validas, rmse_por_corte, linewidth=1.2, alpha=0.35)\n",
    "eje.plot(posiciones_validas, rmse_suavizado, linewidth=2.2)\n",
    "eje.set_title(\"RMSE frente al punto de corte real\")\n",
    "eje.set_xlabel(\"Posición real del punto de cambio\")\n",
    "eje.set_ylabel(\"RMSE\")\n",
    "eje.set_xlim(posiciones_validas.min(), posiciones_validas.max())\n",
    "eje.grid(alpha=0.2)\n",
