    "import random\n",
    "import inspect\n",
    "from dataclasses import dataclass\n",
    "from typing import Tuple\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "\n",
    "from andi_datasets.datasets_theory import datasets_theory\n",
    "\n",
    "\n",
    "@dataclass\n",
    "class Configuracion:\n",
    "    longitud_secuencia: int = 100\n",
    "    longitud_minima_segmento: int = 20\n",
    "    numero_clases: int = 61\n",
    "    dimension: int = 1\n",
    "    tamano_lote: int = 128\n",
    "    numero_epocas: int = 20\n",
    "    tasa_aprendizaje: float = 1e-3\n",
    "    decaimiento_pesos: float = 1e-4\n",
    "    canales_convolucionales: int = 64\n",
    "    tamano_oculto: int = 128\n",
    "    tasa_dropout: float = 0.2\n",
    "    tamano_entrenamiento: int = 20000\n",
    "    tamano_validacion: int = 4000\n",
    "    desviacion_ruido: float = 0.10\n",
    "    semilla: int = 42\n",
    "    dispositivo: str = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "    ruta_modelo: str = \"best_cutpoint_model.pt\"\n",
    "\n",
    "\n",
    "CFG = Configuracion()\n",
    "\n",
    "\n",
    "def fijar_semilla(semilla: int) -> None:\n",
    "    random.seed(semilla)\n",
    "    np.random.seed(semilla)\n",
    "    torch.manual_seed(semilla)\n",
    "    torch.cuda.manual_seed_all(semilla)\n",
    "\n",
    "\n",
    "fijar_semilla(CFG.semilla)\n"
   ]
