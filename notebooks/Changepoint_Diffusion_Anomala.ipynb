    "mejor_modelo = RedPuntoDeCorte(\n",
    "    numero_canales_entrada=3,\n",
    "    canales_convolucionales=CFG.canales_convolucionales,\n",
    "    tamano_oculto=CFG.tamano_oculto,\n",
    "    numero_clases=CFG.numero_clases,\n",
    "    tasa_dropout=CFG.tasa_dropout,\n",
    ").to(CFG.dispositivo)\n",
    "\n",
    "\n",
    "def adaptar_claves_modelo(estado_antiguo):\n",
    "    correspondencias = {\n",
    "        \"conv1\": \"convolucion_1\",\n",
    "        \"bn1\": \"normalizacion_1\",\n",
    "        \"conv2\": \"convolucion_2\",\n",
    "        \"bn2\": \"normalizacion_2\",\n",
    "        \"conv3\": \"convolucion_3\",\n",
    "        \"bn3\": \"normalizacion_3\",\n",
    "        \"bigru\": \"gru_bidireccional\",\n",
    "        \"classifier\": \"clasificador\",\n",
    "    }\n",
    "\n",
    "    estado_nuevo = {}\n",
    "\n",
    "    for clave, valor in estado_antiguo.items():\n",
    "        nueva_clave = clave\n",
    "        for prefijo_antiguo, prefijo_nuevo in correspondencias.items():\n",
    "            if clave.startswith(prefijo_antiguo):\n",
    "                nueva_clave = clave.replace(prefijo_antiguo, prefijo_nuevo, 1)\n",
    "                break\n",
    "        estado_nuevo[nueva_clave] = valor\n",
    "\n",
    "    return estado_nuevo\n",
    "\n",
    "\n",
    "estado_guardado = torch.load(CFG.ruta_modelo, map_location=CFG.dispositivo)\n",
    "\n",
    "# Por si el archivo guardado contiene directamente el state_dict\n",
    "# o viene envuelto en otra estructura.\n",
    "if isinstance(estado_guardado, dict) and \"state_dict\" in estado_guardado:\n",
    "    estado_guardado = estado_guardado[\"state_dict\"]\n",
    "\n",
    "estado_adaptado = adaptar_claves_modelo(estado_guardado)\n",
    "\n",
    "mejor_modelo.load_state_dict(estado_adaptado)\n",
    "mejor_modelo.eval()\n",
    "\n",
    "\n",
    "@torch.no_grad()\n",
    "def recopilar_predicciones_validacion(modelo, dataset, dispositivo):\n",
    "    modelo.eval()\n",
    "\n",
    "    cortes_reales = []\n",
    "    cortes_predichos = []\n",
    "    errores_absolutos = []\n",
    "    ejemplos = []\n",
    "\n",
    "    for indice in range(len(dataset)):\n",
    "        salida = dataset[indice]\n",
    "\n",
    "        if len(salida) == 4:\n",
    "            tensor_entrada, _, tensor_corte, _ = salida\n",
    "        else:\n",
    "            tensor_entrada, _, tensor_corte = salida\n",
    "\n",
    "        puntuaciones = modelo(tensor_entrada.unsqueeze(0).to(dispositivo))\n",
    "        clase_predicha = puntuaciones.argmax(dim=1).item()\n",
    "\n",
    "        corte_predicho = clase_a_corte(\n",
    "            clase_predicha,\n",
    "            longitud_minima_segmento=CFG.longitud_minima_segmento,\n",
    "        )\n",
    "\n",
    "        corte_real = int(tensor_corte.item())\n",
    "        error_absoluto = abs(corte_predicho - corte_real)\n",
    "\n",
    "        cortes_reales.append(corte_real)\n",
    "        cortes_predichos.append(corte_predicho)\n",
    "        errores_absolutos.append(error_absoluto)\n",
    "\n",
    "        ejemplos.append({\n",
    "            \"trayectoria\": tensor_entrada[:, 0].cpu().numpy(),\n",
    "            \"corte_real\": corte_real,\n",
    "            \"corte_predicho\": corte_predicho,\n",
    "            \"error_absoluto\": error_absoluto,\n",
    "        })\n",
    "\n",
    "    return {\n",
    "        \"cortes_reales\": np.array(cortes_reales),\n",
    "        \"cortes_predichos\": np.array(cortes_predichos),\n",
    "        \"errores_absolutos\": np.array(errores_absolutos),\n",
    "        \"ejemplos\": ejemplos,\n",
    "    }\n",
    "\n",
    "\n",
    "resultados_validacion = recopilar_predicciones_validacion(\n",
    "    mejor_modelo,\n",
    "    dataset_validacion,\n",
    "    CFG.dispositivo,\n",
    ")\n",
    "\n",
    "print(\"Número de trayectorias evaluadas:\", len(resultados_validacion[\"cortes_reales\"]))\n",
    "print(\"MAE global:\", resultados_validacion[\"errores_absolutos\"].mean())\n",
    "print(\n",
    "    \"RMSE global:\",\n",
    "    np.sqrt(\n",
    "        np.mean(\n",
    "            (resultados_validacion[\"cortes_predichos\"] - resultados_validacion[\"cortes_reales\"]) ** 2\n",
    "        )\n",
    "    ),\n",
    ")\n",
    "\n",
    "cortes_reales = resultados_validacion[\"cortes_reales\"]\n",
    "cortes_predichos = resultados_validacion[\"cortes_predichos\"]\n",
    "errores_absolutos = resultados_validacion[\"errores_absolutos\"]\n",
    "\n",
    "posiciones_validas = np.arange(\n",
    "    CFG.longitud_minima_segmento,\n",
    "    CFG.longitud_secuencia - CFG.longitud_minima_segmento + 1,\n",
    ")\n",
    "\n",
    "rmse_por_corte = []\n",
    "mae_por_corte = []\n",
    "\n",
    "for posicion in posiciones_validas:\n",
    "    mascara = (cortes_reales == posicion)\n",
    "\n",
    "    if np.sum(mascara) > 0:\n",
    "        errores = cortes_predichos[mascara] - cortes_reales[mascara]\n",
    "        rmse_por_corte.append(np.sqrt(np.mean(errores ** 2)))\n",
    "        mae_por_corte.append(np.mean(np.abs(errores)))\n",
    "    else:\n",
    "        rmse_por_corte.append(np.nan)\n",
    "        mae_por_corte.append(np.nan)\n",
    "\n",
    "rmse_por_corte = np.array(rmse_por_corte, dtype=float)\n",
    "mae_por_corte = np.array(mae_por_corte, dtype=float)\n",
    "\n",
    "\n",
    "def suavizar_curva(y, ventana=5):\n",
    "    y = np.asarray(y, dtype=float)\n",
    "    salida = np.copy(y)\n",
    "\n",
    "    for i in range(len(y)):\n",
    "        izquierda = max(0, i - ventana // 2)\n",
    "        derecha = min(len(y), i + ventana // 2 + 1)\n",
    "\n",
    "        valores = y[izquierda:derecha]\n",
    "        valores = valores[~np.isnan(valores)]\n",
    "\n",
    "        if len(valores) > 0:\n",
    "            salida[i] = np.mean(valores)\n",
    "        else:\n",
    "            salida[i] = np.nan\n",
    "\n",
    "    return salida\n",
    "\n",
    "\n",
    "rmse_suavizado = suavizar_curva(rmse_por_corte, ventana=5)\n",
    "mae_suavizado = suavizar_curva(mae_por_corte, ventana=5)\n",
    "\n",
    "# Se selecciona el ejemplo con menor error absoluto\n",
    "ejemplo = min(\n",
    "    resultados_validacion[\"ejemplos\"],\n",
    "    key=lambda elemento: elemento[\"error_absoluto\"]\n",
    ")\n",
    "\n",
    "trayectoria_ejemplo = ejemplo[\"trayectoria\"]\n",
