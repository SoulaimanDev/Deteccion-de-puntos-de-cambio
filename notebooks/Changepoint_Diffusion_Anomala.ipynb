    "def preparar_trayectoria_individual(trayectoria: np.ndarray) -> torch.Tensor:\n",
    "    if len(trayectoria) != CFG.longitud_secuencia:\n",
    "        raise ValueError(f\"La trayectoria debe tener longitud {CFG.longitud_secuencia}\")\n",
    "\n",
    "    trayectoria = normalizar_trayectoria(np.asarray(trayectoria, dtype=np.float32))\n",
    "    caracteristicas = construir_caracteristicas(trayectoria)\n",
    "\n",
    "    return torch.tensor(caracteristicas, dtype=torch.float32).unsqueeze(0)\n",
    "\n",
    "\n",
    "@torch.no_grad()\n",
    "def predecir_corte(modelo: nn.Module, trayectoria: np.ndarray, dispositivo: str):\n",
    "    modelo.eval()\n",
    "\n",
    "    tensor_entrada = preparar_trayectoria_individual(trayectoria).to(dispositivo)\n",
    "    puntuaciones = modelo(tensor_entrada)\n",
    "    probabilidades = F.softmax(puntuaciones, dim=1).cpu().numpy()[0]\n",
    "\n",
    "    clase_predicha = int(np.argmax(probabilidades))\n",
    "    corte_predicho = clase_a_corte(\n",
    "        clase_predicha,\n",
    "        longitud_minima_segmento=CFG.longitud_minima_segmento,\n",
    "    )\n",
    "\n",
    "    return clase_predicha, corte_predicho, probabilidades\n",
    "\n",
    "\n",
    "mejor_modelo = RedPuntoDeCorte(\n",
    "    numero_canales_entrada=3,\n",
    "    canales_convolucionales=CFG.canales_convolucionales,\n",
    "    tamano_oculto=CFG.tamano_oculto,\n",
    "    numero_clases=CFG.numero_clases,\n",
    "    tasa_dropout=CFG.tasa_dropout,\n",
    ").to(CFG.dispositivo)\n",
    "\n",
    "\n",
    "def adaptar_claves_modelo(estado_antiguo):\n",
    "    correspondencias = {\n",
    "        \"conv1\": \"convolucion_1\",\n",
    "        \"bn1\": \"normalizacion_1\",\n",
    "        \"conv2\": \"convolucion_2\",\n",
    "        \"bn2\": \"normalizacion_2\",\n",
    "        \"conv3\": \"convolucion_3\",\n",
    "        \"bn3\": \"normalizacion_3\",\n",
    "        \"bigru\": \"gru_bidireccional\",\n",
    "        \"classifier\": \"clasificador\",\n",
    "    }\n",
    "\n",
    "    estado_nuevo = {}\n",
    "\n",
    "    for clave, valor in estado_antiguo.items():\n",
    "        nueva_clave = clave\n",
    "        for prefijo_antiguo, prefijo_nuevo in correspondencias.items():\n",
    "            if clave.startswith(prefijo_antiguo):\n",
    "                nueva_clave = clave.replace(prefijo_antiguo, prefijo_nuevo, 1)\n",
    "                break\n",
    "        estado_nuevo[nueva_clave] = valor\n",
    "\n",
    "    return estado_nuevo\n",
    "\n",
    "\n",
    "estado_guardado = torch.load(CFG.ruta_modelo, map_location=CFG.dispositivo)\n",
    "estado_adaptado = adaptar_claves_modelo(estado_guardado)\n",
    "\n",
    "mejor_modelo.load_state_dict(estado_adaptado)\n",
    "mejor_modelo.eval()\n",
    "\n",
    "entrada_ejemplo, clase_ejemplo, corte_ejemplo = dataset_validacion[0]\n",
    "\n",
    "clase_predicha, corte_predicho, probabilidades = predecir_corte(\n",
    "    mejor_modelo,\n",
    "    entrada_ejemplo[:, 0].cpu().numpy(),\n",
    "    CFG.dispositivo,\n",
    ")\n",
    "\n",
    "print(\"Corte real:\", int(corte_ejemplo))\n",
    "print(\"Corte estimado:\", corte_predicho)\n",
    "print(\"Clase estimada:\", clase_predicha)\n",
    "print(\"Probabilidad máxima:\", float(probabilidades[clase_predicha]))\n",
    "\n",
    "trayectoria = entrada_ejemplo[:, 0].cpu().numpy()\n",
    "tiempo = np.arange(len(trayectoria))\n",
    "corte_real = int(corte_ejemplo.item())\n",
    "\n",
    "color_izquierda = \"royalblue\"\n",
    "color_derecha = \"crimson\"\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 4.8))\n",
    "\n",
    "ax.axvspan(0, corte_real, color=color_izquierda, alpha=0.12)\n",
    "ax.axvspan(corte_real, len(tiempo) - 1, color=color_derecha, alpha=0.12)\n",
    "\n",
    "ax.plot(\n",
    "    tiempo[:corte_real],\n",
    "    trayectoria[:corte_real],\n",
    "    linewidth=2.2,\n",
    "    color=color_izquierda,\n",
    ")\n",
    "ax.plot(\n",
    "    tiempo[corte_real - 1:],\n",
    "    trayectoria[corte_real - 1:],\n",
    "    linewidth=2.2,\n",
    "    color=color_derecha,\n",
    ")\n",
    "\n",
    "ax.axvline(corte_real, color=\"black\", linestyle=\"--\", linewidth=1.8, label=\"Corte real\")\n",
    "ax.axvline(corte_predicho, color=\"black\", linestyle=\":\", linewidth=1.8, label=\"Corte estimado\")\n",
    "\n",
    "ax.text(\n",
    "    0.20,\n",
    "    0.88,\n",
    "    \"Régimen 1\",\n",
    "    transform=ax.transAxes,\n",
    "    color=color_izquierda,\n",
    "    fontsize=13,\n",
    "    ha=\"center\",\n",
    "    va=\"top\",\n",
    ")\n",
    "\n",
    "ax.text(\n",
    "    0.80,\n",
    "    0.88,\n",
    "    \"Régimen 2\",\n",
    "    transform=ax.transAxes,\n",
    "    color=color_derecha,\n",
    "    fontsize=13,\n",
    "    ha=\"center\",\n",
    "    va=\"top\",\n",
    ")\n",
    "\n",
    "ax.text(\n",
    "    corte_real + 1,\n",
    "    np.min(trayectoria) + 0.10 * (np.max(trayectoria) - np.min(trayectoria)),\n",
    "    \"Punto de cambio real\",\n",
    "    fontsize=11,\n",
    ")\n",
    "\n",
    "ax.set_title(\"Inferencia sobre una nueva trayectoria\", fontsize=15)\n",
    "ax.set_xlabel(\"Tiempo\", fontsize=13)\n",
    "ax.set_ylabel(\"Posición normalizada\", fontsize=13)\n",
    "ax.legend(frameon=False, fontsize=11)\n",
    "ax.grid(alpha=0.25)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
