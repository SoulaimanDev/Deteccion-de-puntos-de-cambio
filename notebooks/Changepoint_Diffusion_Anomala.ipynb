    "## Generación de trayectorias con `andi_datasets`\n",
    "\n",
    "La generación del conjunto de datos sintético se apoya en la librería `andi_datasets`, desarrollada para simular trayectorias asociadas a distintos modelos de difusión anómala. En este trabajo, cada segmento se genera de manera independiente a partir de uno de los modelos disponibles, seleccionando además un valor del exponente anómalo compatible con la dinámica considerada.\n",
    "\n",
    "Con el fin de incorporar esta etapa al procedimiento general, se define una clase auxiliar encargada de generar pares modelo-exponente y de adaptar la salida de `andi_datasets` a un formato homogéneo y utilizable por el resto del proceso. Esta adaptación resulta especialmente relevante, ya que la estructura exacta de la salida puede variar en función de la versión instalada de la librería."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "cd4a4d87-df03-4cb4-9650-e48b3b56d205",
   "metadata": {},
   "outputs": [],
   "source": [
    "class GeneradorAndi:\n",
    "    def __init__(self, dimension: int = 1):\n",
    "        self.dimension = dimension\n",
    "        self.dt = datasets_theory()\n",
    "\n",
    "        self.modelo_a_id = {\n",
    "            \"attm\": 0,\n",
    "            \"ctrw\": 1,\n",
    "            \"fbm\": 2,\n",
    "            \"lw\": 3,\n",
    "            \"sbm\": 4,\n",
    "        }\n",
    "\n",
    "        self.rangos_alpha = {\n",
    "            \"attm\": (0.05, 1.0),\n",
    "            \"ctrw\": (0.05, 1.0),\n",
    "            \"fbm\": (0.05, 1.95),\n",
    "            \"lw\": (1.0, 2.0),\n",
    "            \"sbm\": (0.05, 2.0),\n",
    "        }\n",
    "\n",
    "        self.modelos = list(self.modelo_a_id.keys())\n",
    "\n",
    "    def seleccionar_alpha_para_modelo(self, modelo: str) -> float:\n",
    "        limite_inferior, limite_superior = self.rangos_alpha[modelo]\n",
    "        return float(np.random.uniform(limite_inferior, limite_superior))\n",
    "\n",
    "    def seleccionar_modelo_y_alpha(self) -> Tuple[str, float]:\n",
    "        modelo = random.choice(self.modelos)\n",
    "        alpha = self.seleccionar_alpha_para_modelo(modelo)\n",
    "        return modelo, alpha\n",
    "\n",
    "    def ajustar_alpha_al_rango(self, modelo: str, alpha: float) -> float:\n",
    "        limite_inferior, limite_superior = self.rangos_alpha[modelo]\n",
    "        return float(np.clip(alpha, limite_inferior, limite_superior))\n",
    "\n",
    "    def seleccionar_par(self, modo_seleccion: str = \"equilibrado\"):\n",
    "        if modo_seleccion == \"aleatorio\":\n",
    "            modelo_izquierdo, alpha_izquierdo = self.seleccionar_modelo_y_alpha()\n",
    "            modelo_derecho, alpha_derecho = self.seleccionar_modelo_y_alpha()\n",
    "            return (\n",
    "                modelo_izquierdo,\n",
    "                alpha_izquierdo,\n",
    "                modelo_derecho,\n",
    "                alpha_derecho,\n",
    "                \"aleatorio\",\n",
    "            )\n",
    "\n",
    "        casos_transicion = [\n",
    "            \"mismo_modelo_alpha_similar\",\n",
    "            \"mismo_modelo_alpha_diferente\",\n",
    "            \"modelo_distinto_alpha_similar\",\n",
    "            \"modelo_distinto_alpha_diferente\",\n",
    "        ]\n",
    "\n",
    "        caso = random.choice(casos_transicion)\n",
    "\n",
    "        if caso == \"mismo_modelo_alpha_similar\":\n",
    "            modelo = random.choice(self.modelos)\n",
    "            alpha_izquierdo = self.seleccionar_alpha_para_modelo(modelo)\n",
    "            desplazamiento = np.random.uniform(-0.05, 0.05)\n",
    "            alpha_derecho = self.ajustar_alpha_al_rango(\n",
    "                modelo,\n",
    "                alpha_izquierdo + desplazamiento,\n",
    "            )\n",
    "            return modelo, alpha_izquierdo, modelo, alpha_derecho, caso\n",
    "\n",
    "        if caso == \"mismo_modelo_alpha_diferente\":\n",
    "            modelo = random.choice(self.modelos)\n",
    "            alpha_izquierdo = self.seleccionar_alpha_para_modelo(modelo)\n",
    "\n",
    "            alpha_derecho = self.seleccionar_alpha_para_modelo(modelo)\n",
    "            while abs(alpha_derecho - alpha_izquierdo) < 0.25:\n",
    "                alpha_derecho = self.seleccionar_alpha_para_modelo(modelo)\n",
    "\n",
    "            return modelo, alpha_izquierdo, modelo, alpha_derecho, caso\n",
    "\n",
    "        if caso == \"modelo_distinto_alpha_similar\":\n",
    "            while True:\n",
    "                modelo_izquierdo = random.choice(self.modelos)\n",
    "                modelo_derecho = random.choice(self.modelos)\n",
    "\n",
    "                if modelo_izquierdo == modelo_derecho:\n",
    "                    continue\n",
    "\n",
    "                limite_inferior_izquierdo, limite_superior_izquierdo = self.rangos_alpha[modelo_izquierdo]\n",
    "                limite_inferior_derecho, limite_superior_derecho = self.rangos_alpha[modelo_derecho]\n",
    "\n",
    "                solapamiento_inferior = max(limite_inferior_izquierdo, limite_inferior_derecho)\n",
    "                solapamiento_superior = min(limite_superior_izquierdo, limite_superior_derecho)\n",
    "\n",
    "                if solapamiento_inferior < solapamiento_superior:\n",
    "                    alpha_referencia = float(\n",
    "                        np.random.uniform(solapamiento_inferior, solapamiento_superior)\n",
    "                    )\n",
    "                    alpha_izquierdo = self.ajustar_alpha_al_rango(\n",
    "                        modelo_izquierdo,\n",
    "                        alpha_referencia + np.random.uniform(-0.05, 0.05),\n",
    "                    )\n",
    "                    alpha_derecho = self.ajustar_alpha_al_rango(\n",
    "                        modelo_derecho,\n",
    "                        alpha_referencia + np.random.uniform(-0.05, 0.05),\n",
    "                    )\n",
    "                    return modelo_izquierdo, alpha_izquierdo, modelo_derecho, alpha_derecho, caso\n",
    "\n",
    "        if caso == \"modelo_distinto_alpha_diferente\":\n",
    "            modelo_izquierdo = random.choice(self.modelos)\n",
    "            modelo_derecho = random.choice(self.modelos)\n",
    "\n",
    "            while modelo_derecho == modelo_izquierdo:\n",
    "                modelo_derecho = random.choice(self.modelos)\n",
    "\n",
    "            alpha_izquierdo = self.seleccionar_alpha_para_modelo(modelo_izquierdo)\n",
    "            alpha_derecho = self.seleccionar_alpha_para_modelo(modelo_derecho)\n",
    "\n",
    "            intentos = 0\n",
    "            while abs(alpha_derecho - alpha_izquierdo) < 0.25 and intentos < 50:\n",
    "                alpha_derecho = self.seleccionar_alpha_para_modelo(modelo_derecho)\n",
    "                intentos += 1\n",
    "\n",
    "            return modelo_izquierdo, alpha_izquierdo, modelo_derecho, alpha_derecho, caso\n",
    "\n",
    "        raise ValueError(f\"Modo de selección no reconocido: {modo_seleccion}\")\n",
    "\n",
    "    def generar_segmento(self, longitud: int, nombre_modelo: str, alpha: float) -> np.ndarray:\n",
    "        id_modelo = self.modelo_a_id[nombre_modelo]\n",
    "\n",
    "        argumentos_candidatos = {\n",
    "            \"T\": longitud,\n",
    "            \"N_models\": 1,\n",
    "            \"exponents\": [alpha],\n",
    "            \"models\": [id_modelo],\n",
    "            \"dimension\": self.dimension,\n",
    "            \"N\": 1,\n",
    "        }\n",
    "\n",
    "        firma = inspect.signature(self.dt.create_dataset)\n",
    "        argumentos_validos = {\n",
    "            clave: valor\n",
    "            for clave, valor in argumentos_candidatos.items()\n",
    "            if clave in firma.parameters\n",
    "        }\n",
    "\n",
    "        salida = self.dt.create_dataset(**argumentos_validos)\n",
    "\n",
    "        if isinstance(salida, tuple):\n",
    "            trayectorias = salida[0]\n",
    "        else:\n",
    "            trayectorias = salida\n",
    "\n",
    "        trayectorias = np.asarray(trayectorias)\n",
    "\n",
    "        if trayectorias.ndim == 3:\n",
    "            trayectoria = trayectorias[0, :, 0]\n",
    "        elif trayectorias.ndim == 2:\n",
    "            fila = trayectorias[0]\n",
    "            if fila.shape[0] == longitud:\n",
    "                trayectoria = fila\n",
    "            elif fila.shape[0] > longitud:\n",
    "                trayectoria = fila[-longitud:]\n",
    "            else:\n",
    "                raise ValueError(f\"No se ha podido interpretar la forma {trayectorias.shape}\")\n",
    "        elif trayectorias.ndim == 1:\n",
    "            if trayectorias.shape[0] == longitud:\n",
    "                trayectoria = trayectorias\n",
    "            elif trayectorias.shape[0] > longitud:\n",
    "                trayectoria = trayectorias[-longitud:]\n",
    "            else:\n",
    "                raise ValueError(f\"No se ha podido interpretar la forma {trayectorias.shape}\")\n",
    "        else:\n",
    "            raise ValueError(f\"Forma inesperada de salida: {trayectorias.shape}\")\n",
    "\n",
    "        return np.asarray(trayectoria, dtype=np.float32)"
   ]
