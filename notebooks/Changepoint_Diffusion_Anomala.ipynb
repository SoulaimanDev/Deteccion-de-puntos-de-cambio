    "## Funciones auxiliares\n",
    "\n",
    "Las funciones que se introducen a continuación permiten codificar la posición del punto de cambio como una etiqueta discreta, normalizar las trayectorias y construir una representación basada en posiciones e incrementos. Estas operaciones facilitan el entrenamiento del modelo y mejoran la calidad de la información suministrada a la red neuronal."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "3f5dbfb7-98d9-4993-b89f-74e630e76f79",
   "metadata": {},
   "outputs": [],
   "source": [
    "def corte_a_clase(indice_corte: int, longitud_minima_segmento: int = 20) -> int:\n",
    "    return indice_corte - longitud_minima_segmento\n",
    "\n",
    "\n",
    "def clase_a_corte(indice_clase: int, longitud_minima_segmento: int = 20) -> int:\n",
    "    return indice_clase + longitud_minima_segmento\n",
    "\n",
    "\n",
    "def normalizar_trayectoria(x: np.ndarray) -> np.ndarray:\n",
    "    x = x.astype(np.float32)\n",
    "    x = x - x[0]\n",
    "\n",
    "    desviacion = x.std()\n",
    "    if desviacion < 1e-8:\n",
    "        desviacion = 1.0\n",
    "\n",
    "    return x / desviacion\n",
    "\n",
    "\n",
    "def construir_caracteristicas(x: np.ndarray) -> np.ndarray:\n",
    "    incrementos = np.diff(x, prepend=x[0]).astype(np.float32)\n",
    "\n",
    "    desviacion_incrementos = incrementos.std()\n",
    "    if desviacion_incrementos < 1e-8:\n",
    "        desviacion_incrementos = 1.0\n",
    "\n",
    "    incrementos_normalizados = incrementos / desviacion_incrementos\n",
    "    valor_absoluto_incrementos = np.abs(incrementos_normalizados)\n",
    "\n",
    "    return np.stack(\n",
    "        [x, incrementos_normalizados, valor_absoluto_incrementos],\n",
    "        axis=-1\n",
    "    ).astype(np.float32)"
   ]
  },
